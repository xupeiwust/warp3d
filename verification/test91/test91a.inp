!
! DJGM CP model  -- cubic volume
!
 structure voided_blk
! 
 crystal 1
      properties slip_type hcp18 elastic_type ti6242,
      mu_0 1.3281250e+5,
      D_0 1.5937500e+5,
      T_0 7.6562500e+4,
      e 6.7187500e+4,
      nu 2.8125000e+4,
      voche_m 3.9843750e+4,
      theta_0 -1.0000000e+00,
      k_0 -1.0000000e+02,
      u_1 -5.0000000e+01,
      u_2 -1.0382500e+02,
      u_3 -3.1147500e+02,
      u_4 1.2000000e-01,
      u_5 1.2000000e-01,
      u_6 1.2000000e-01,
      u_7 4.2000000e+01,
      u_8 4.2000000e+01,
      u_9 4.2000000e+01,
      u_10 3.0000000e-01,
      p_y 2.9000000e-01,
      p_v 2.9000000e-01,
      q_y 1.4000000e-01,
      q_v 1.5000000e-01,
      boltz 1.5000000e-01,
      b 2.0000000e-01,
      tau_a 2.0000000e-01,
      tau_hat_v 2.0000000e-01,
      g_0_y 3.7500000e+01,
      eps_dot_0_y 3.0000000e+01,
      g_0_v 9.0000000e+01,
      hardening djgm xtol 1.0e-4,
      solver tr method 3 miter 40
!
! material definition
!
 material titanium_djgm
      properties cp alpha 1.08E-5 rho 0.0 angle_convention kocks,
      n_crystals 1 angle_type degrees, 
      crystal_input single crystal_type 1,
      orientation_input file filename 'block_angles.inp',
      debug off tolerance 1.0E-10
! 
 number of nodes 342 elements 208
!
 elements
  1-208 type l3disop  nlgeom material titanium_djgm,
              order 2x2x2 bbar center_output short
!
*input from 'bulk_data.inp' $ coords, incid, blking, pressures
!
 constraints
    plane x=0 symmetry
    plane y=0 symmetry
    plane z=0 symmetry
!
 loading test
  nonlinear
    step 1-4 unit_biaxial 500.0e-3
    step 5 6 7 8 9 10 unit_biaxial 60.0e-3
!
initial conditions
  temperatures
     1-342 temperature 300
!
 output model flat patran convention text file "model.text"
! 
 nonlinear analysis parameters
   solution technique asymmetric iterative
   time step 1.0e06 
   maximum iterations 8
   minimum iterations 2
   divergence check on
   convergence test norm res tol 0.01
   nonconvergent solutions stop
   adaptive off  $ global Newton iterations
   batch messages off
   wall time limit off
   material messages off
   bbar stabilization factor 0.0
   consistent q-matrix on
   trace solution on
   extrapolate on
   display tied mesh mpcs off
   user_routine off
! 
! 
 output commands use file "block_get_output.inp" steps 6-10
 compute displacements for loading test step 10 $ 6
!
stop
